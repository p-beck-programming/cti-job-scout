# Copy to .env for local runs (and `export $(grep -v '^#' .env | xargs)` or
# use direnv). In GitHub Actions these come from repo secrets/variables —
# never commit real values.

# --- LLM provider (scoring, via LiteLLM) ---
# Set the API key matching the provider in JOBSCOUT_MODEL below. Only the
# key for the provider you actually use is required.
ANTHROPIC_API_KEY=sk-ant-...
# OPENAI_API_KEY=sk-...
# GEMINI_API_KEY=...
# Any LiteLLM-supported provider works; key env var names are listed at
# https://docs.litellm.ai/docs/providers

# --- Gmail API (digest sending) ---
# Produced by scripts/get_gmail_refresh_token.py; see README "Gmail API setup".
GMAIL_CLIENT_ID=1234567890-abc.apps.googleusercontent.com
GMAIL_CLIENT_SECRET=GOCSPX-...
GMAIL_REFRESH_TOKEN=1//0g...

# Where the daily digest is delivered.
DIGEST_RECIPIENT=you@example.com

# --- Tuning (optional) ---
# Minimum LLM relevance score (0-100) for a posting to make the digest.
SCORE_THRESHOLD=60
# Public URL of the dashboard (GitHub Pages), linked from each digest email.
DASHBOARD_URL=
# Scoring model, as a LiteLLM "<provider>/<model>" string, e.g.
# anthropic/claude-sonnet-4-6, openai/gpt-4o, gemini/gemini-2.0-flash,
# ollama/llama3. Full list: https://docs.litellm.ai/docs/providers
JOBSCOUT_MODEL=anthropic/claude-sonnet-4-6
# Set to 1 to run the full pipeline without sending email (great first run).
DRY_RUN=
